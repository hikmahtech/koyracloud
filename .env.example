# koyracloud control plane configuration. Copy to .env (gitignored) and fill in.
# NEVER commit real secret values.

# --- State -------------------------------------------------------------------
# SQLite (default, self-contained) or Postgres, e.g.:
#   postgresql+psycopg://koyracloud:<pw>@postgres:5432/koyracloud
DB_URL=sqlite:///./data/koyracloud.db

# --- Crypto / sessions -------------------------------------------------------
# Fernet key for encrypting secrets at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
KOYRA_SECRET_KEY=
# Random string for signing session cookies (e.g. `openssl rand -hex 32`).
KOYRA_SESSION_SECRET=

# --- GitHub ------------------------------------------------------------------
# OAuth App (login + allowlist). Register at github.com/settings/developers with
# callback https://<your-control-plane-domain>/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# A token the builder uses to clone (private) repos.
GITHUB_PAT=
# Comma-separated GitHub logins allowed to sign in (fail-closed if empty).
KOYRA_ALLOWED_LOGINS=your-github-login

# Local-dev only: set to a login to bypass OAuth entirely. Leave blank in prod.
KOYRA_DEV_LOGIN=

# --- Swarm / Traefik / NFS ---------------------------------------------------
# The shared runtime image (build it from runtime-image/ and push, or load it
# onto your nodes). See deploy/README.md.
KOYRA_RUNTIME_IMAGE=koyracloud-runtime:latest
# Base path on the nodes for per-app volumes (NFS-backed in a multi-node swarm).
KOYRA_NFS_BASE=/mnt/koyracloud
KOYRA_TRAEFIK_NETWORK=traefik_public
KOYRA_CERT_RESOLVER=letsencrypt
KOYRA_HTTPS_ENTRYPOINT=websecure
# Default subdomain suffix for apps: <name>.<KOYRA_APPS_DOMAIN>
KOYRA_APPS_DOMAIN=apps.example.com
KOYRA_BASE_URL=https://koyracloud.example.com
# Public IP your edge answers on — shown as the DNS hint for custom domains.
KOYRA_PUBLIC_IP=
# Optional: pin apps to one node (needed if the runtime image is only present
# locally on that node, i.e. no registry). Empty = schedule anywhere.
KOYRA_APP_NODE=
KOYRA_RESOLVE_IMAGE_NEVER=
