# Copy to deploy/koyracloud.env (gitignored) and fill in for your instance.
# Sourced by deploy/deploy.sh and interpolated into koyracloud-stack.yml.

# Control-plane host (the UI) and its public base URL.
KOYRA_HOST=koyracloud.example.com
KOYRA_BASE_URL=https://koyracloud.example.com

# Default URL suffix for deployed apps: <name>-<token>.<KOYRA_APPS_DOMAIN>
# (a random per-app token keeps names from colliding). Keep this ONE label deep
# (e.g. apps.example.com, not foo.apps.example.com) so a single free wildcard
# TLS cert for *.<KOYRA_APPS_DOMAIN> covers every app, and point a wildcard DNS
# record *.<KOYRA_APPS_DOMAIN> at your edge so the default URLs resolve.
KOYRA_APPS_DOMAIN=apps.example.com
# Set to 1 only if *.<KOYRA_APPS_DOMAIN> is fronted by a proxy that terminates
# TLS (e.g. Cloudflare with a proxied wildcard over a tunnel). Traefik then skips
# Let's Encrypt for auto-subdomains since the edge already serves their cert.
# Leave blank for a self-host with open 80/443 (Traefik gets LE certs itself).
KOYRA_APPS_DOMAIN_PROXIED=

# Public IP your edge answers on (shown as the DNS hint for custom domains).
KOYRA_PUBLIC_IP=203.0.113.10

# Google Analytics 4 Measurement ID (public, e.g. G-XXXXXXXXXX). Leave blank to
# ship no analytics. Baked into the SPA's <head> at build time by deploy.sh.
KOYRA_GA_MEASUREMENT_ID=

# GitHub OAuth App client id (not sensitive; secret + PAT are Docker secrets).
GITHUB_CLIENT_ID=
# Comma-separated GitHub logins allowed to sign in.
KOYRA_ALLOWED_LOGINS=your-github-login

# Where per-app volumes live on the nodes (NFS-backed for multi-node swarms).
KOYRA_NFS_BASE=/mnt/koyracloud
# NFS server IP for the registry + app persist volumes. When set, Docker mounts
# the NFS itself on whichever node runs the container, so nothing is pinned.
# Leave empty to use plain bind mounts (single-node / local).
KOYRA_NFS_SERVER=

# Manager hostname to pin the control plane to (it needs the docker socket and,
# without a registry, the locally-built image).
KOYRA_CONTROL_NODE=

# Apps are built into per-app images and pushed to the internal registry (the
# `registry` service in the stack), then pulled by swarm on whichever node runs
# them — so leave these empty/0 for multi-node HA. Only pin KOYRA_APP_NODE if you
# deliberately want all apps on one host.
KOYRA_APP_NODE=
KOYRA_RESOLVE_IMAGE_NEVER=0

# Internal registry apps are pushed to + the LOCAL build dir (off NFS).
KOYRA_REGISTRY=127.0.0.1:5000
KOYRA_BUILD_DIR=/tmp/koyra-build

# Base image koyracloud builds app images FROM (has python+node+git). Apps that
# ship their own Dockerfile (.paas/app.yaml runtime: dockerfile) ignore this.
KOYRA_RUNTIME_IMAGE=koyracloud-runtime:latest
KOYRA_TRAEFIK_NETWORK=traefik_public

# Shared Redis bus (the `redis` service). Apps opt in with `redis: true` and get
# a scoped ACL user + injected REDIS_URL. The admin password is the Docker secret
# koyra_redis_admin_password; a blank secret disables the bus. Use the
# fully-qualified service name `koyracloud_redis`, NOT the bare `redis` alias:
# the control plane also joins the `monitoring` overlay, where a standalone
# redis is aliased `redis` too, so the bare name can resolve to the wrong
# instance and fail ACL auth. maxmemory caps the instance (noeviction → writes
# back-pressure when full instead of dropping queued messages).
KOYRA_REDIS_HOST=koyracloud_redis
KOYRA_REDIS_PORT=6379
KOYRA_REDIS_MAXMEMORY=256mb
# Cron scheduler (launches due jobs as Swarm run-to-completion jobs). Set to 0
# to disable; blank/1 = on.
KOYRA_CRON_ENABLED=

# SQLite backups (ignored on Postgres). A consistent snapshot is taken every
# INTERVAL_HOURS and the newest KEEP are kept. Point BACKUP_DIR at a mount
# SEPARATE from the DB volume so a volume loss doesn't take both; blank => the
# default <db-dir>/backups. Restore with `python -m koyracloud.backup restore`
# (see docs/DISASTER-RECOVERY.md).
KOYRA_BACKUP_ENABLED=
KOYRA_BACKUP_INTERVAL_HOURS=
KOYRA_BACKUP_KEEP=
KOYRA_BACKUP_DIR=

# Email alerts (Resend) — leave RESEND_API_KEY blank to keep notifications off.
RESEND_API_KEY=
# quote values with spaces/<> so deploy.sh can source the file
KOYRA_EMAIL_FROM="koyracloud <alerts@yourdomain.com>"
KOYRA_DEFAULT_NOTIFY_EMAIL=

# Cloudflare for SaaS — auto-register user custom domains as custom hostnames so
# the edge mints their TLS cert (Vercel-style). The token is a Docker secret
# (koyra_cloudflare_api_token); leave the zone id blank to keep the feature off.
# Find the zone id on the Cloudflare dashboard → your SaaS zone → Overview.
KOYRA_CLOUDFLARE_ZONE_ID=
# Proxied CNAME the customer points their domain at (the SaaS fallback origin).
KOYRA_CLOUDFLARE_SAAS_ORIGIN=origin.example.com
