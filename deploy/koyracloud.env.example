# Copy to deploy/koyracloud.env (gitignored) and fill in for your instance.
# Sourced by deploy/deploy.sh and interpolated into koyracloud-stack.yml.

# Control-plane host (the UI) and its public base URL.
KOYRA_HOST=koyracloud.example.com
KOYRA_BASE_URL=https://koyracloud.example.com

# Default subdomain suffix for deployed apps: <name>.<KOYRA_APPS_DOMAIN>
KOYRA_APPS_DOMAIN=apps.example.com

# Public IP your edge answers on (shown as the DNS hint for custom domains).
KOYRA_PUBLIC_IP=203.0.113.10

# GitHub OAuth App client id (not sensitive; secret + PAT are Docker secrets).
GITHUB_CLIENT_ID=
# Comma-separated GitHub logins allowed to sign in.
KOYRA_ALLOWED_LOGINS=your-github-login

# Where per-app volumes live on the nodes (NFS-backed for multi-node swarms).
KOYRA_NFS_BASE=/mnt/koyracloud

# Manager hostname to pin the control plane to (it needs the docker socket and,
# without a registry, the locally-built image).
KOYRA_CONTROL_NODE=

# No-registry app deploys: pin apps to this node and skip registry resolution.
# Leave empty if you push the runtime image to a registry reachable by all nodes.
KOYRA_APP_NODE=
KOYRA_RESOLVE_IMAGE_NEVER=1

# The runtime image apps run (build from runtime-image/ and push, or load on nodes).
KOYRA_RUNTIME_IMAGE=koyracloud-runtime:latest
KOYRA_TRAEFIK_NETWORK=traefik_public
